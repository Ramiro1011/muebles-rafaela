{
	"name": "muebles-rafaela",
	"compatibility_date": "2026-07-06",
	"main": "worker/index.js",
	"vars": {
		"FIREBASE_PROJECT_ID": "muebles-rafaela"
	},
	"assets": {
		"directory": "./build",
		"binding": "ASSETS",
		"not_found_handling": "single-page-application",
		"run_worker_first": ["/api/*"]
	}
}
